# ── Core ─────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Auth: Single user (legacy) ────────────────────────────────────────────────
ALLOWED_USER_ID=your_telegram_user_id_here

# ── Auth: Multi-user (new) ────────────────────────────────────────────────────
# Comma-separated Telegram user IDs. Overrides ALLOWED_USER_ID if set.
# ALLOWED_USER_IDS=123456789,987654321
# ADMIN_USER_IDS=123456789

# ── LLM Providers ────────────────────────────────────────────────────────────
CEREBRAS_API_KEY=your_cerebras_key
GROQ_API_KEY=your_groq_key
GEMINI_API_KEY=your_gemini_key
OPENROUTER_API_KEY=your_openrouter_key
ZAI_API_KEY=your_zai_key
OPENAI_API_KEY=your_openai_key_optional

# ── Voice / Whisper ───────────────────────────────────────────────────────────
# Uses GROQ_API_KEY (whisper-large-v3, free) by default.
# Set OPENAI_API_KEY above for OpenAI Whisper (whisper-1).
# Or: pip install openai-whisper for fully local transcription.

# ── Discord Bridge (optional) ─────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ── Artifact Preview Server ───────────────────────────────────────────────────
ARTIFACT_PORT=8765

# ── Streaming ─────────────────────────────────────────────────────────────────
STREAM_RESPONSES=true

# ── Persistence ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Optional: Local Ollama ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
