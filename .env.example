# Legion Telegram Bot — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to version control.

# ============================================================
# REQUIRED
# ============================================================

# Your Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram user ID (get it from @userinfobot)
ALLOWED_USER_ID=123456789

# Optional multi-user mode
ALLOWED_USER_IDS=
ADMIN_USER_IDS=
ADMIN_USER_ID=

# ============================================================
# LLM PROVIDERS (at least one cloud key required)
# ============================================================

# Cerebras — fastest (1500 tok/s), best for quick tasks
CEREBRAS_API_KEY=

# Groq — fast + supports function calling
GROQ_API_KEY=

# Google Gemini — 1M context window
GEMINI_API_KEY=

# OpenRouter — access to 100+ models incl. free tier
OPENROUTER_API_KEY=

# ZAI / GLM-4 — strong at debug + math
ZAI_API_KEY=

# HuggingFace — for local/HF models
HF_TOKEN=

# ============================================================
# SUPABASE (required for /dbquery /dbhealth /dbtables)
# ============================================================

# Found at: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OPTIONAL INTEGRATIONS
# ============================================================

# OpenAI (used for whisper transcription in /voice)
OPENAI_API_KEY=

# Brave Search API (used for /research /scrape)
BRAVE_API_KEY=

# GitHub Personal Access Token (used for /git commands)
GITHUB_TOKEN=

# Telegram channel/group for /post command
TELEGRAM_CHANNEL_ID=

# Task/project integrations
TODOIST_API_KEY=
LINEAR_API_KEY=

# Email (used for /email command)
EMAIL_ADDRESS=
EMAIL_APP_PASSWORD=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Discord bridge (optional)
DISCORD_BOT_TOKEN=

# Artifact preview web server
ARTIFACT_PORT=8765

# Streaming responses toggle
STREAM_RESPONSES=true

# WorkerNet + briefing
WORKERNET_LOG_PATH=
CITY_FOR_WEATHER=Jakarta

# OpenClaw bridge
OPENCLAW_PORT=3456

# Local model gating thresholds
LOCAL_MIN_FREE_RAM_GB=3.0
LOCAL_MIN_FREE_VRAM_GB=4.0
LOCAL_MIN_FREE_VRAM_PCT=25

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# VS Code bridge workspace root
VSCODE_WORKSPACE=/home/newadmin

# Legacy watchdog variable (optional)
BOT_TOKEN=

# ============================================================
# LOCAL LLM (optional, for offline use)
# ============================================================

# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Default local model to use
OLLAMA_MODEL=llama3.2
