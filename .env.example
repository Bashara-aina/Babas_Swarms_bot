# BabasSwarms — copy this to .env and fill in real values
# NEVER commit .env to git

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_ID=your_telegram_user_id_here

# ── Cloud LLM APIs (need at least ONE) ────────────────────
# Cerebras: fastest (~1,500 tok/s) — free tier: 14,400 req/day
# Get at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Groq: fast (~241 tok/s) — free tier: generous daily limit
# Get at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gemini: 1M context window — free tier available
# Get at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter: 24+ free models, fallback of last resort
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ZAI/GLM-4: optional, strong reasoning (GPQA Diamond 85.7%)
# Get at: https://bigmodel.cn/usercenter/apikeys
ZAI_API_KEY=your_zai_api_key_here

# HuggingFace: optional, for HF inference endpoints
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# ── WAJAR_WATCH: regulation monitoring ───────────────────
# GitHub PAT with 'repo' scope for opening PRs on slip_cekwajar_id
CEKWAJAR_GITHUB_TOKEN=your_github_pat_here

# Supabase project for regulation tracking tables
CEKWAJAR_SUPABASE_URL=https://your-project.supabase.co
CEKWAJAR_SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Telegram chat ID for WAJAR_WATCH alerts (same as ALLOWED_USER_ID usually)
WAJAR_WATCH_ALERT_CHAT_ID=your_telegram_user_id_here

# Auto-merge PRs after CI passes? Default: false (Safety Rule 2)
WAJAR_WATCH_AUTO_MERGE_ENABLED=false
